<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MVVM.ViewModels"
        x:Class="MVVM.Views.InventoryWindow"
        x:DataType="vm:EmployeeViewModel"
        Title="Инвентаризация"
        Width="450" Height="400"
        Background="#6B5CA8"
        WindowStartupLocation="CenterOwner">

    <Border Background="#FFF9FB"
        Padding="20"
        CornerRadius="14">

    <StackPanel Spacing="14">

        <TextBlock Text="Состояние оборудования:"
                   Foreground="#9D174D"
                   FontWeight="SemiBold"/>

        <ComboBox ItemsSource="{Binding InventoryStates}"
                  SelectedItem="{Binding SelectedInventoryState}"
                  Width="220"
                  Background="#FCE7F3"
                  BorderBrush="#F472B6"
                  BorderThickness="1"
                  CornerRadius="8"
                  Foreground="#4B5563"/>

        <CheckBox Content="Присутствует"
                  IsChecked="{Binding CurrentInventory.IsPresent}"
                  Foreground="#9D174D"
                  FontWeight="SemiBold"/>

        <TextBlock Text="Местоположение:"
                   Foreground="#9D174D"
                   FontWeight="SemiBold"/>

        <TextBox Text="{Binding CurrentInventory.Location}"
                 Width="320"
                 Background="#FFF1F6"
                 Foreground="#4B5563"
                 BorderBrush="#F472B6"
                 BorderThickness="1"
                 CornerRadius="8"
                 CaretBrush="#BE185D"/>

        <TextBlock Text="Комментарий:"
                   Foreground="#9D174D"
                   FontWeight="SemiBold"/>

        <TextBox Text="{Binding CurrentInventory.Comments}"
                 AcceptsReturn="True"
                 Height="90"
                 Width="420"
                 Background="#FFF1F6"
                 Foreground="#4B5563"
                 BorderBrush="#F472B6"
                 BorderThickness="1"
                 CornerRadius="10"
                 CaretBrush="#BE185D"/>

        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,10,0,0">

            <Button Content="Прикрепить фото"
                    Command="{Binding AttachPhotoCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Width="170"
                    Height="38"
                    Background="#EC4899"
                    Foreground="White"
                    CornerRadius="10">

                <Button.Styles>
                    <Style Selector="Button:hover">
                        <Setter Property="Background" Value="#BE185D"/>
                    </Style>
                </Button.Styles>
            </Button>

            <Button Content="Сохранить"
                    Command="{Binding SaveInventoryCommand}"
                    Width="200"
                    Height="38"
                    Background="#BE185D"
                    Foreground="White"
                    CornerRadius="10">

                <Button.Styles>
                    <Style Selector="Button:hover">
                        <Setter Property="Background" Value="#9D174D"/>
                    </Style>
                </Button.Styles>
            </Button>

        </StackPanel>

    </StackPanel>
</Border>
</Window>