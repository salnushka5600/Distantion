<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MVVM.ViewModels"
        xmlns:equipment="clr-namespace:MVVM.Models.Dto.Equipment"
        xmlns:dashboard="clr-namespace:MVVM.Models.Dto.DashBoard"
        x:Class="MVVM.Views.EmployeeMainWindow"
        x:DataType="vm:EmployeeViewModel"
        Title="Сотрудник"
        Width="900" Height="600"
        Background="#F3E8FF">

    <TabControl Background="#FFF9FB">
    <TabControl.Styles>

        <Style Selector="TabItem">
            <Setter Property="Background" Value="#FCE7F3"/>
            <Setter Property="Foreground" Value="#9D174D"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="#EC4899"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="#EC4899"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style Selector="Button:hover">
            <Setter Property="Background" Value="#BE185D"/>
        </Style>

    </TabControl.Styles>


    <TabItem Header="Моё оборудование">
        <StackPanel Margin="20" Spacing="12">

            <Border Background="HotPink"
                    Padding="10"
                    CornerRadius="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Id" Width="50" FontWeight="SemiBold" Foreground="#9D174D"/>
                    <TextBlock Text="Наименование" Width="200" FontWeight="SemiBold" Foreground="#9D174D"/>
                    <TextBlock Text="Статус" Width="100" FontWeight="SemiBold" Foreground="#9D174D"/>
                    <TextBlock Text="Категория" Width="150" FontWeight="SemiBold" Foreground="#9D174D"/>
                    <TextBlock Text="Стоимость" Width="100" FontWeight="SemiBold" Foreground="#9D174D"/>
                </StackPanel>
            </Border>

            <ListBox x:Name="EquipmentList"
                     ItemsSource="{Binding MyEquipments}"
                     SelectedItem="{Binding SelectedEquipment}"
                     Background="Transparent"
                     BorderThickness="0">

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="equipment:EquipmentShortResponse">
                        <Border Background="#FFF1F6"
                                CornerRadius="10"
                                Padding="10"
                                Margin="4">

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding Id}" Width="50" Foreground="#9D174D"/>
                                <TextBlock Text="{Binding Name}" Width="200" Foreground="#4B5563"/>
                                <TextBlock Text="{Binding Status}" Width="100" Foreground="#BE185D"/>
                                <TextBlock Text="{Binding Category}" Width="150" Foreground="#4B5563"/>
                                <TextBlock Text="{Binding Cost, StringFormat=C}" Width="100" Foreground="#9D174D"/>
                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Content="Провести инвентаризацию"
                    Width="200"
                    Height="42"
                    IsEnabled="{Binding CanStartInventory}"
                    Command="{Binding StartInventoryAsync}"
                    CommandParameter="{Binding SelectedEquipment}"
                    Margin="0,10,0,0"/>

        </StackPanel>
    </TabItem>


    <TabItem Header="История">
        <ScrollViewer Margin="20">
            <StackPanel Spacing="12">

                <Border Background="#FCE7F3"
                        Padding="10"
                        CornerRadius="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Дата следующей инвентаризации"
                                   Width="220"
                                   FontWeight="SemiBold"
                                   Foreground="#9D174D"/>

                        <TextBlock Text="Дней до инвентаризации"
                                   Width="180"
                                   FontWeight="SemiBold"
                                   Foreground="#9D174D"/>
                    </StackPanel>
                </Border>

                <ListBox ItemsSource="{Binding InventoryHistory}"
                         Background="Transparent"
                         BorderThickness="0">

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="dashboard:NextInventoryInfo">
                            <Border Background="#FFF1F6"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="4">

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding NextInventoryDate, StringFormat=dd.MM.yyyy}"
                                               Width="220"
                                               Foreground="#4B5563"/>

                                    <TextBlock Text="{Binding DaysLeft}"
                                               Width="180"
                                               FontWeight="Bold"
                                               Foreground="#BE185D"/>
                                </StackPanel>

                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

            </StackPanel>
        </ScrollViewer>
    </TabItem>

</TabControl>
</Window>